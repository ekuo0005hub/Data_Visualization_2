{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Average Water Runoff by State (2001–2021)",
    "subtitle": "NSW dominates upstream water availability; SA receives the least",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "color": "#1a1a2e"
  },
  "width": 500,
  "height": 380,
  "projection": {"type": "mercator", "center": [135, -27], "scale": 750},
  "layer": [
    {
      "data": {
        "url": "data/australia_states.geojson",
        "format": {"type": "json", "property": "features"}
      },
      "transform": [
        {
          "lookup": "properties.STATE_NAME",
          "from": {
            "data": {"url": "data/state_avg_supply.csv"},
            "key": "STATE_NAME",
            "fields": ["avg_runoff_GL"]
          }
        }
      ],
      "mark": {"type": "geoshape", "stroke": "#fff", "strokeWidth": 1},
      "encoding": {
        "color": {
          "condition": {
            "test": "datum.avg_runoff_GL != null",
            "field": "avg_runoff_GL",
            "type": "quantitative",
            "scale": {"scheme": "blues", "domain": [0, 3500]},
            "legend": {"title": "Avg Runoff (GL)", "orient": "bottom-right"}
          },
          "value": "#e8f4f0"
        },
        "tooltip": [
          {"field": "properties.STATE_NAME", "type": "nominal", "title": "State"},
          {"field": "avg_runoff_GL", "type": "quantitative", "title": "Avg Runoff (GL)", "format": ",.0f"}
        ]
      }
    },
    {
      "data": {"values": [
        {"lon": 146.5, "lat": -32.0, "label": "NSW\n3,385 GL"},
        {"lon": 144.5, "lat": -36.5, "label": "VIC\n1,463 GL"},
        {"lon": 135.5, "lat": -30.0, "label": "SA\n230 GL"}
      ]},
      "mark": {"type": "text", "fontSize": 11, "fontWeight": "bold", "color": "#1a1a2e"},
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "label", "type": "nominal"}
      }
    }
  ]
}
