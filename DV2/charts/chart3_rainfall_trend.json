{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Annual Rainfall Decline — Wagga Wagga (NSW) 1960–2024",
    "subtitle": "BOM Station 065000 — a key southern basin region",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "color": "#1a1a2e"
  },
  "width": 600,
  "height": 260,
  "data": {"url": "data/rainfall_wagga.csv"},
  "layer": [
    {
      "mark": {"type": "area", "color": "#2a9d8f", "opacity": 0.2, "line": false},
      "encoding": {
        "x": {"field": "year", "type": "quantitative", "axis": {"title": "Year", "format": "d"}},
        "y": {"field": "rainfall_mm", "type": "quantitative", "axis": {"title": "Annual Rainfall (mm)"}}
      }
    },
    {
      "mark": {"type": "line", "color": "#2a9d8f", "strokeWidth": 1.5},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall_mm", "type": "quantitative"}
      }
    },
    {
      "mark": {"type": "line", "color": "#e63946", "strokeWidth": 2.5, "strokeDash": [6,3]},
      "transform": [{"regression": "rainfall_mm", "on": "year"}],
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall_mm", "type": "quantitative"}
      }
    },
    {
      "data": {"values": [
        {"year": 2002, "rainfall_mm": 900, "label": "2002–03 Drought"},
        {"year": 2018, "rainfall_mm": 900, "label": "2018–19 Drought"}
      ]},
      "mark": {"type": "rule", "color": "#e63946", "strokeDash": [4,4], "opacity": 0.6},
      "encoding": {"x": {"field": "year", "type": "quantitative"}}
    },
    {
      "data": {"values": [
        {"year": 2002, "rainfall_mm": 920, "label": "2002 Drought"},
        {"year": 2018, "rainfall_mm": 920, "label": "2018 Drought"}
      ]},
      "mark": {"type": "text", "fontSize": 10, "color": "#e63946", "dy": -5},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {"field": "rainfall_mm", "type": "quantitative"},
        "text": {"field": "label"}
      }
    }
  ]
}
