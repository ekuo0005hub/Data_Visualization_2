{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Agricultural Value by Industry — Murray-Darling Basin",
    "subtitle": "Select a year to explore how industry contributions shift with water availability",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "color": "#1a1a2e"
  },
  "width": 500,
  "height": 320,
  "data": {"url": "data/gviap_by_industry.csv"},
  "params": [
    {
      "name": "year_select",
      "value": 2019,
      "bind": {
        "input": "range",
        "min": 2006, "max": 2020, "step": 1,
        "name": "Select Year: "
      }
    }
  ],
  "transform": [
    {"filter": "datum.Year == year_select"},
    {"filter": "datum.gviap_billion > 0"}
  ],
  "mark": {"type": "arc", "innerRadius": 60, "outerRadius": 140, "stroke": "#fff", "strokeWidth": 1.5},
  "encoding": {
    "theta": {"field": "gviap_billion", "type": "quantitative", "stack": true},
    "color": {
      "field": "Industry", "type": "nominal",
      "scale": {"scheme": "tableau10"},
      "legend": {"title": "Industry", "orient": "right"}
    },
    "tooltip": [
      {"field": "Industry", "title": "Industry"},
      {"field": "Year", "title": "Year"},
      {"field": "gviap_billion", "type": "quantitative", "title": "Value ($B)", "format": ".2f"}
    ]
  }
}
