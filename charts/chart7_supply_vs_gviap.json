{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Water Supply vs Agricultural Value",
    "subtitle": "When water runs low, agricultural output drops. Two datasets merged by year.",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "color": "#1a1a2e"
  },
  "width": 600,
  "height": 280,
  "data": {"url": "data/supply_vs_gviap.csv"},
  "layer": [
    {
      "mark": {"type": "line", "color": "#457b9d", "strokeWidth": 2.5, "point": {"filled": true, "color": "#457b9d", "size": 60}},
      "encoding": {
        "x": {"field": "year", "type": "quantitative", "axis": {"title": "Year", "format": "d"}},
        "y": {
          "field": "total_runoff_GL",
          "type": "quantitative",
          "axis": {"title": "Water Supply Total Runoff (GL)", "titleColor": "#457b9d"},
          "scale": {"domain": [3000, 11000]}
        },
        "tooltip": [
          {"field": "year", "type": "quantitative", "title": "Year"},
          {"field": "total_runoff_GL", "type": "quantitative", "title": "Runoff (GL)", "format": ",.0f"},
          {"field": "gviap_billion", "type": "quantitative", "title": "Ag Value ($B)", "format": ".2f"}
        ]
      }
    },
    {
      "mark": {"type": "line", "color": "#e76f51", "strokeWidth": 2.5, "strokeDash": [6,3], "point": {"filled": true, "color": "#e76f51", "size": 60}},
      "encoding": {
        "x": {"field": "year", "type": "quantitative"},
        "y": {
          "field": "gviap_billion",
          "type": "quantitative",
          "axis": {"title": "Agricultural Output ($AUD Billion)", "titleColor": "#e76f51"},
          "scale": {"domain": [4, 10]}
        }
      }
    }
  ],
  "resolve": {"scale": {"y": "independent"}}
}
