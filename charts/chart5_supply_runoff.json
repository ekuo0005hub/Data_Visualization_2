{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Total Basin Water Supply (Runoff) by Year 2001–2021",
    "subtitle": "Combined runoff from all 14 MDB catchment regions (GL)",
    "fontSize": 14,
    "subtitleFontSize": 11,
    "color": "#1a1a2e"
  },
  "width": 600,
  "height": 260,
  "data": {"url": "data/supply_annual.csv"},
  "layer": [
    {
      "mark": {"type": "area", "color": "#457b9d", "opacity": 0.25, "line": false}
    },
    {
      "mark": {"type": "line", "color": "#457b9d", "strokeWidth": 2, "point": {"filled": true, "color": "#457b9d", "size": 50}}
    },
    {
      "data": {"values": [{"year": 2007, "y": 9000, "label": "Millennium Drought peak"}, {"year": 2019, "y": 9000, "label": "2019 Drought"}]},
      "mark": {"type": "rule", "color": "#e63946", "strokeDash": [4,4], "opacity": 0.7},
      "encoding": {"x": {"field": "year", "type": "quantitative"}}
    }
  ],
  "encoding": {
    "x": {"field": "year", "type": "quantitative", "axis": {"title": "Year", "format": "d"}},
    "y": {"field": "total_runoff_GL", "type": "quantitative", "axis": {"title": "Total Runoff (GL)"}},
    "tooltip": [
      {"field": "year", "type": "quantitative", "title": "Year"},
      {"field": "total_runoff_GL", "type": "quantitative", "title": "Total Runoff (GL)", "format": ",.0f"}
    ]
  }
}
